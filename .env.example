DATABASE_URL="postgresql://placeholder:placeholder@localhost:5432/placeholder"
NEXTAUTH_SECRET="replace-with-a-local-secret"
NEXTAUTH_URL="http://localhost:3000"
OLLAMA_BASE_URL="http://localhost:11434"
ATLAS_BRAIN_MODEL="atlas-brain"

# Atlas Connect token encryption
# Required before live OAuth tokens can be stored. Use a long random secret in local/dev and a managed secret in production.
ATLAS_TOKEN_ENCRYPTION_KEY=""

# Atlas Connect - Google Workspace read-only adapter
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/connect/google/callback"
GOOGLE_CONNECT_SCOPES="openid email profile https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/calendar.readonly"
